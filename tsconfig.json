{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "types": ["node", "@playwright/test"]
  },

  "include": [
    "**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}